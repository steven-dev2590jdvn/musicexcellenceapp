<?xml version='1.0' encoding='utf-8'?><widget id="com.musicexcellence.app" version="1.0.0"
xmlns="http://www.w3.org/ns/widgets"
xmlns:cdv="http://cordova.apache.org/ns/1.0">

<name>Music Excellence</name>

<description>
    Music Excellence
</description>

<author email="you@example.com" href="https://musicexcellence.com">
    Music Excellence
</author>

<content src="index.html" />

<!-- Allow network access -->
<access origin="*" />

<!-- Allow navigation to external sites -->
<allow-navigation href="*" />

<!-- Allow opening external links -->
<allow-intent href="http://*/*" />
<allow-intent href="https://*/*" />
<allow-intent href="tel:*" />
<allow-intent href="sms:*" />
<allow-intent href="mailto:*" />
<allow-intent href="geo:*" />

<platform name="ios">
    <preference name="scheme" value="app" />
</platform>

</widget>